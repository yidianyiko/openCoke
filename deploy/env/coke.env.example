# Coke production environment example
# Copy to .env on the deployment host and replace all placeholder values.

# Shared runtime
OPENAI_API_KEY=replace-me
COKE_BRIDGE_API_KEY=replace-me
# Must match the public browser origin; update this alongside domain changes.
COKE_WEB_ALLOWED_ORIGIN=https://coke.keep4oforever.com
CLAWSCALE_IDENTITY_API_KEY=replace-me
CLAWSCALE_OUTBOUND_API_KEY=replace-me
CLAWSCALE_WECHAT_CHANNEL_API_KEY=replace-me

# Gateway member auth
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Coke user auth
COKE_JWT_SECRET=replace-me-with-a-different-long-random-string

# Public URLs
DOMAIN_CLIENT=https://coke.keep4oforever.com
CORS_ORIGIN=https://coke.keep4oforever.com
# NEXT_PUBLIC_API_URL is the gateway web bundle API target.
NEXT_PUBLIC_API_URL=https://coke.keep4oforever.com
# NEXT_PUBLIC_COKE_API_URL is the Coke-user frontend API target.
NEXT_PUBLIC_COKE_API_URL=https://coke.keep4oforever.com

# Stripe
STRIPE_SECRET_KEY=replace-me
STRIPE_WEBHOOK_SECRET=replace-me
STRIPE_PRICE_ID=price_replace_me

# Email delivery
RESEND_API_KEY=replace-me
EMAIL_FROM=noreply@keep4oforever.com
EMAIL_FROM_NAME=Coke
